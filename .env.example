# Darwin — Environment Variables

# Required for researcher agent (Tavily MCP)
# Get your key at https://tavily.com
# TAVILY_API_KEY=tvly-xxxxx

# Required for investigator agent (SearXNG via mcp-research)
# Point to your SearXNG instance
# SEARXNG_URL=http://localhost:8080

# Optional: Override default model (default: claude-sonnet-4-20250514)
# DARWIN_MODEL=claude-opus-4-20250926

# Optional: PostgreSQL connection (Pro tier)
# DARWIN_POSTGRES_URL=postgresql://user:pass@localhost:5432/darwin

# ─── Multi-Model Providers ───────────────────────────

# Anthropic API (direct, 10-100x faster than CLI for non-MCP agents)
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI / OpenAI-compatible (GPT-4o, Together AI, Groq, etc.)
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama (local, no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434
